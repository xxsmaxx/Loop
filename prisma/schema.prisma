generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ANALYST
  VIEWER
}

enum Sentiment {
  POS
  NEU
  NEG
}

enum FeedbackStatus {
  NEW
  REVIEWED
  ACTIONED
}

enum FeedbackChannel {
  SUPPORT
  APP_STORE
  SURVEY
  SALES
  SOCIAL
  CHAT
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users     User[]
  feedbacks Feedback[]
  themes    Theme[]
  reports   Report[]
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(VIEWER)
  createdAt    DateTime @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  reports Report[]

  @@index([workspaceId])
}

model Feedback {
  id             String         @id @default(cuid())
  content        String
  channel        FeedbackChannel
  sourceRef      String?
  customerLabel  String?
  sentiment      Sentiment      @default(NEU)
  sentimentScore Float          @default(0)
  status         FeedbackStatus @default(NEW)
  featureArea    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  feedbackThemes FeedbackTheme[]
  embedding      Embedding?

  @@index([workspaceId])
  @@index([status])
  @@index([sentiment])
  @@index([channel])
  @@index([createdAt])
}

model Theme {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#3B82F6")
  createdAt   DateTime @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  feedbackThemes FeedbackTheme[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model FeedbackTheme {
  feedbackId String
  themeId    String
  confidence Float @default(0.7)

  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  theme    Theme    @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@id([feedbackId, themeId])
}

model Embedding {
  id         String   @id @default(cuid())
  feedbackId String  @unique
  vectorJson Json
  createdAt  DateTime @default(now())

  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
}

model Report {
  id          String   @id @default(cuid())
  title       String
  periodStart DateTime
  periodEnd   DateTime
  contentJson Json
  createdAt   DateTime @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  generatedById String
  generatedBy   User @relation(fields: [generatedById], references: [id])

  @@index([workspaceId])
  @@index([createdAt])
}
